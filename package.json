{
  "name": "@zairakai/js-dev-tools",
  "version": "1.0.0",
  "description": "The unified and centralized development toolkit for JavaScript/TypeScript projects - ESLint, Prettier, Stylelint, Knip, Vitest, Git Hooks, and GitLab CI pipeline templates",
  "keywords": [
    "dev-tools",
    "toolkit",
    "unified",
    "centralized",
    "makefile",
    "git-hooks",
    "gitlab-ci",
    "eslint",
    "prettier",
    "stylelint",
    "vitest",
    "knip",
    "typescript"
  ],
  "homepage": "https://gitlab.com/zairakai/npm-packages/js-dev-tools",
  "bugs": {
    "url": "https://gitlab.com/zairakai/npm-packages/js-dev-tools/-/issues",
    "email": "contact-project+zairakai-npm-packages-js-dev-tools-80188322-issue-@incoming.gitlab.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/zairakai/npm-packages/js-dev-tools.git"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/zairakai"
    },
    {
      "type": "twitch",
      "url": "https://www.twitch.tv/zairakai"
    }
  ],
  "license": "MIT",
  "author": "Stanislas Poisson <stanislas.p@the-white-rabbits.fr> (https://the-white-rabbits.fr)",
  "contributors": [
    {
      "name": "Stanislas Poisson",
      "url": "https://gitlab.com/zairakai",
      "role": "Maintainer"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./prettier": "./config/prettier.config.js",
    "./eslint": "./config/eslint.config.js",
    "./stylelint": "./config/stylelint.config.js",
    "./vitest": "./config/vitest.config.js",
    "./knip": "./config/knip.config.js",
    "./tsconfig": "./config/tsconfig.base.json",
    "./config/*": "./config/*"
  },
  "main": "index.js",
  "files": [
    ".gitlab/",
    "config/",
    "scripts/",
    "stubs/",
    "tools/",
    "index.js",
    ".editorconfig",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "eslint": "eslint --config config/eslint.config.js config/*.{js,ts}",
    "eslint:fix": "eslint --config config/eslint.config.js config/*.{js,ts} --fix",
    "postinstall": "bash ./scripts/setup-project.sh --silent || true",
    "knip": "bash ./scripts/knip.sh",
    "markdownlint": "markdownlint-cli2 --config config/.markdownlint.json --ignore-path config/.markdownlintignore '**/*.md' '#node_modules'",
    "markdownlint:fix": "markdownlint-cli2 --fix --config config/.markdownlint.json --ignore-path config/.markdownlintignore '**/*.md' '#node_modules'",
    "normalize": "make package-normalize",
    "package:validate": "make package-validate",
    "prettier": "prettier . --check --config ./config/prettier.config.js --ignore-path ./config/.prettierignore",
    "prettier:fix": "prettier . --write --config ./config/prettier.config.js --ignore-path ./config/.prettierignore",
    "setup": "bash ./scripts/setup-project.sh",
    "stylelint": "stylelint --config config/stylelint.config.js --ignore-path config/.stylelintignore '**/*.scss'",
    "stylelint:fix": "stylelint --config config/stylelint.config.js --ignore-path config/.stylelintignore '**/*.scss' --fix",
    "test": "make test-all",
    "validate": "make quality"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.0",
    "@prettier/plugin-php": "^0.25.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.5.0",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.8.3",
    "prettier-plugin-blade": "^2.1.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "stylelint": "^17.8.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.0.0",
    "stylelint-scss": "^7.0.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.4.1",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typedoc": "^0.28.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "stylelint": {
      "optional": true
    },
    "typedoc": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "outdatedIgnore": [
    "prettier-plugin-blade"
  ]
}
