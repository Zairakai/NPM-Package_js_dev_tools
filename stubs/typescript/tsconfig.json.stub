{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@zairakai/js-dev-tools/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "build", "**/*.test.ts", "**/*.spec.ts"]
}
